{
  "name": "agent-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run build:client && CI=1 HOME=.wrangler-home wrangler dev",
    "build": "bun run typecheck && bun run build:client && CI=1 HOME=.wrangler-home wrangler deploy --dry-run --outdir dist/worker",
    "build:client": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "latest",
    "@vitejs/plugin-react": "latest",
    "ai": "latest",
    "hono": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
