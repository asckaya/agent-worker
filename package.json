{
  "name": "agent-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run build:client && CI=1 HOME=.wrangler-home wrangler dev",
    "build": "bun run typecheck && bun run build:client",
    "build:client": "vite build",
    "deploy:dry-run": "bun run build && CI=1 HOME=.wrangler-home wrangler deploy --dry-run --outdir dist/worker",
    "telegram:set-commands": "bun run scripts/telegram-set-commands.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:full": "bun run test && bun run deploy:dry-run"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "latest",
    "@octokit/request": "latest",
    "@vitejs/plugin-react": "latest",
    "ai": "latest",
    "fast-xml-parser": "latest",
    "hono": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
